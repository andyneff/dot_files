#!/usr/bin/env false bash

#alias uv-install='curl -LsSf https://astral.sh/uv/install.sh | sh'

function uv-install()
{
  if [ "${1-}" = "--dir" ]; then
    local UV_INSTALL_DIR=${UV_INSTALL_DIR-${2}}
    export UV_INSTALL_DIR
    shift 2
  fi
  curl -LsSf https://astral.sh/uv/install.sh | sh ${@+"${@}"}
}
